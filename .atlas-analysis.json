  "keyFeatures": [
    "Create, read, update, and delete financial transactions (income and expenses)",
    "Filter transactions by type, category, month, and year",
    "General balance calculation (total income, total expenses, net balance)",
    "Spending summary grouped by category with percentage breakdown",
    "Monthly summary with month-over-month comparison and percentage change",
    "Top 5 spending categories ranked by total amount",
    "Retrieve all available transaction years",
    "Predefined and custom categories (food, transport, entertainment, utilities, health, shopping, salary, other)",
    "Input validation via Zod schemas",
    "CORS support with configurable origins"
  ],
  "publicApiSurface": [
    "GET /api/transactions",
    "POST /api/transactions",
    "GET /api/transactions/:id",
    "PATCH /api/transactions/:id",
    "DELETE /api/transactions/:id",
    "GET /api/transactions/years",
    "GET /api/stats/balance",
    "GET /api/stats/by-category",
    "GET /api/stats/monthly",
    "GET /api/stats/top-categories",
    "GET /api/categories",
    "GET /api/categories/:id",
    "POST /api/categories",
    "PUT /api/categories/:id",
    "DELETE /api/categories/:id"
  ]
}
